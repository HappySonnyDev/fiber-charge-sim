# Production environment for Next.js app (server-side + NEXT_PUBLIC_*)
# Copy to /opt/fiber-charge-sim/.env and fill in real values.
#
# IMPORTANT: After editing, run `systemctl restart fiber-charge-app`.

# ============================================
# Public domain (sslip.io) and Router pubkey
# ============================================
# Replace 1-2-3-4 with your VPS IP using dashes (sslip.io trick).
# Example: VPS 199.255.97.215  -> 199-255-97-215.sslip.io
NEXT_PUBLIC_FIBER_BOOTNODE=/dns4/__DOMAIN__/tcp/8231/wss
NEXT_PUBLIC_ROUTER_PUBKEY=0x__ROUTER_PUBKEY__
NEXT_PUBLIC_ROUTER_WS_ADDRESS=/dns4/__DOMAIN__/tcp/8231/wss/p2p/__ROUTER_PUBKEY__

# Optional: Station pubkeys exposed to browser
# NEXT_PUBLIC_STATION_1_PUBKEY=0x
# NEXT_PUBLIC_STATION_2_PUBKEY=0x
# NEXT_PUBLIC_STATION_3_PUBKEY=0x
# NEXT_PUBLIC_STATION_4_PUBKEY=0x

# ============================================
# Server-side: RPC URLs (loopback - same VPS)
# ============================================
FIBER_RPC_URL=http://127.0.0.1:8227
STATION_1_RPC_URL=http://127.0.0.1:8237
STATION_2_RPC_URL=http://127.0.0.1:8247
STATION_3_RPC_URL=http://127.0.0.1:8257
STATION_4_RPC_URL=http://127.0.0.1:8267
# STATION_5_RPC_URL=  # Blink: routed via Router

# ============================================
# Router hop_hints for multi-hop invoices
# ============================================
ROUTER_PUBKEY=__ROUTER_PUBKEY__
ROUTER_FEE_RATE=0.10
STATION_1_CHANNEL_OUTPOINT=0x
STATION_2_CHANNEL_OUTPOINT=0x
STATION_3_CHANNEL_OUTPOINT=0x
STATION_4_CHANNEL_OUTPOINT=0x

# ============================================
# Charging / L402 settings
# ============================================
SERVICE_FEE_RATE=0
INVOICE_AMOUNT_CKB=0.5
PAYMENT_INTERVAL_MS=5000
# L402_ROOT_KEY=<64 hex chars - generate with: openssl rand -hex 32>

# ============================================
# Database (SQLite path on VPS)
# ============================================
DATABASE_PATH=/opt/fiber-charge-sim/data/app.db
