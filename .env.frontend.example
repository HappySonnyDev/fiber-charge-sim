# Fiber Charge Simulator - Frontend Environment Variables
# Copy this file to .env and customize if needed

# ============================================
# WebSocket Proxy Configuration
# ============================================
# These values are pre-configured for your current server setup
# Only change if you move to a different server or change ports

# Your external IP address (auto-detected: 199.255.97.215)
VITE_FIBER_BOOTNODE=/ip4/199.255.97.215/tcp/8231/ws

# Router pubkey (auto-detected from your Router node)
VITE_ROUTER_PUBKEY=0x03a14ea2a93b52fafa23edc29a2b90a1319e328665a5636163a18a0eea6588e2af

# Full WebSocket address with Router pubkey
VITE_ROUTER_WS_ADDRESS=/ip4/199.255.97.215/tcp/8231/ws/p2p/03a14ea2a93b52fafa23edc29a2b90a1319e328665a5636163a18a0eea6588e2af

# ============================================
# Station Pubkeys (Optional - for real payments)
# ============================================
# These are needed if you want to display real station balances
# Get them from: ./fnn-cli -u http://127.0.0.1:8X27 info | grep pubkey
# VITE_STATION_1_PUBKEY=0x
# VITE_STATION_2_PUBKEY=0x
# VITE_STATION_3_PUBKEY=0x
# VITE_STATION_4_PUBKEY=0x
