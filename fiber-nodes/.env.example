# Fiber Node Configuration
# Copy this file to .env and fill in your values

# Router Node (Required - must be running for payments to work)
ROUTER_NODE_NAME=FiberRouter
ROUTER_FIBER_RPC_URL=127.0.0.1:8227
ROUTER_FIBER_WS_URL=ws://127.0.0.1:8228
ROUTER_CKB_RPC_URL=https://testnet.ckbapp.dev
ROUTER_CKB_WS_URL=wss://testnet.ckbapp.dev/ws
# Generate with: ckb-cli util key-info --privkey-path router_key
ROUTER_PRIVATE_KEY=your_router_private_key_here

# Station Nodes (Optional - for real settlement tracking)
TESLA_NODE_NAME=TeslaStation
TESLA_FIBER_RPC_URL=127.0.0.1:8237
TESLA_FIBER_WS_URL=ws://127.0.0.1:8238
TESLA_PRIVATE_KEY=your_tesla_private_key_here

NIO_NODE_NAME=NIOStation
NIO_FIBER_RPC_URL=127.0.0.1:8247
NIO_FIBER_WS_URL=ws://127.0.0.1:8248
NIO_PRIVATE_KEY=your_nio_private_key_here

XPENG_NODE_NAME=XPengStation
XPENG_FIBER_RPC_URL=127.0.0.1:8257
XPENG_FIBER_WS_URL=ws://127.0.0.1:8258
XPENG_PRIVATE_KEY=your_xpeng_private_key_here

EA_NODE_NAME=EAStation
EA_FIBER_RPC_URL=127.0.0.1:8267
EA_FIBER_WS_URL=ws://127.0.0.1:8268
EA_PRIVATE_KEY=your_ea_private_key_here
